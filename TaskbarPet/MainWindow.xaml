<Window x:Class="TaskbarPet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Width="200" Height="200">

    <Window.Resources>
        <tb:TaskbarIcon
            x:Key="TrayIconResource"
            IconSource="/Assets/tray-icon.ico"
            ToolTipText="Taskbar Pet"
            MenuActivation="LeftOrRightClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Feed" Click="OnFeedClicked" />
                    <MenuItem Header="Pause" Click="OnPauseClicked" />
                    <Separator />
                    <MenuItem Header="Settings" Click="OnSettingsClicked" />
                    <MenuItem Header="Exit" Click="OnExitClicked" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Window.Resources>

    <!-- Placeholder: temporary visual to verify window positioning -->
    <Border Background="#20000000" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="8">
        <TextBlock Text="Pet Window" Foreground="White" 
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
</Window>
